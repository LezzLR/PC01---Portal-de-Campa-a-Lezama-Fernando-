@model List<PortalCampanas.Models.Campana>

<h2>Listado de campañas</h2>

<table>
    <tr>
        <th>Nombre</th>
        <th>Categoria</th>
        <th>Estado</th>
        <th>Canal</th>
        <th>Descuento</th>
        <th>Detalle</th>
    </tr>

@foreach(var c in Model)
{
    <tr>
        <td>@c.Nombre</td>
        <td>@c.Categoria</td>
        <td>@c.Estado</td>
        <td>@c.Canal</td>
        <td>@c.DescuentoPct %</td>

        <td>
            <a href="/Campanas/Detalle/@c.Id">
                Ver detalle
            </a>
        </td>
    </tr>
}

</table>